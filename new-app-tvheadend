# TVHEADEND ENDPOINT HARDWARE INTEGRATION TARGETS
# =========================================================
TVH_HOST = "127.0.0.1"
TVH_PORT = "9981"
TVH_USER = ""       # Add your local authentication username if configured
TVH_PASS = ""       # Add your local authentication password if configured

def make_tvh_request(endpoint, post_data=None):
    """Executes a live synchronous network request targeting the Tvheadend API."""
    auth_prefix = f"{TVH_USER}:{TVH_PASS}@" if TVH_USER and TVH_PASS else ""
    url = f"http://{auth_prefix}{TVH_HOST}:{TVH_PORT}{endpoint}"
    try:
        req = urllib.request.Request(url)
        if post_data:
            data = urllib.parse.urlencode(post_data).encode('utf-8')
            req.data = data
        with urllib.request.urlopen(req, timeout=4) as response:
            return json.loads(response.read().decode('utf-8'))
    except Exception as e:
        print(f"Tvheadend Hardware Endpoint connection failed [{endpoint}]: {e}")
        return None

# =========================================================
# REAL-TIME ASYNC NETWORK DEMODULATOR SCAN ENGINE
# =========================================================
class TvheadendHardwareScanWorker(QThread):
    progress_updated = pyqtSignal(int, str, list)
    scan_finished = pyqtSignal(list)

    def run(self):
        """Asynchronously forces a real network mux evaluation loop inside the backend."""
        # 1. Look for a configured DVB adapter network interface
        networks = make_tvh_request("/api/mpegts/network/grid")
        if networks and "entries" in networks and networks["entries"]:
            net_uuid = networks["entries"][0].get("uuid")
            if net_uuid:
                # Trigger real hardware multiplex sweep loop interrupt
                make_tvh_request("/api/mpegts/network/scan", {"uuid": net_uuid})

        # 2. Track real physical tuning locking progress
        for progress in range(10, 101, 10):
            self.msleep(150)
            status_text = "Parsing backend service structures..."
            
            mux_data = make_tvh_request("/api/mpegts/mux/grid", {"limit": 50})
            if mux_data and "entries" in mux_data:
                active_sweeps = [m for m in mux_data["entries"] if m.get("scan_state", 0) != 0]
                if active_sweeps:
                    status_text = f"Hardware Tuning: {active_sweeps[0].get('name', 'Locking Mux')}..."

            # Pull current channels assigned on the tuner cards
            ch_data = make_tvh_request("/api/channel/grid", {"limit": 150})
            current_channels = []
            if ch_data and "entries" in ch_data:
                current_channels = [
                    {"uuid": e.get("uuid"), "name": e.get("name"), "number": e.get("number", 0)}
                    for e in ch_data["entries"] if e.get("name")
                ]
            
            self.progress_updated.emit(progress, status_text, current_channels)
            
        self.scan_finished.emit(current_channels)

