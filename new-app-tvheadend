    def execute_hardware_rf_scan(self):
        self.scan_worker = TvheadendHardwareScanWorker()
        self.scan_worker.progress_updated.connect(self.handle_scan_tick_update)
        self.scan_worker.scan_finished.connect(self.handle_scan_completion)
        self.scan_worker.start()

    def handle_scan_tick_update(self, progress, status, channels):
        self.pbar_scan.setValue(progress)
        self.lbl_scan_status.setText(status)
        self.discovered_channels = channels
        self.lbl_channels_found_cnt.setText(f"Verified Services: {len(self.discovered_channels)}")

    def handle_scan_completion(self, channels):
        self.sync_dvr_recordings_from_backend()
        self.initialize_dashboard_content_grids()
        if self.discovered_channels:
            self.current_channel_index = 0
            self.master_stack.setCurrentIndex(self.STAGE_LIVE_TV)
            self.player_container.play_live_channel(self.discovered_channels[0]["uuid"])
        else:
            self.transition_to_dashboard()

    def sync_dvr_recordings_from_backend(self):
        dvr_data = make_tvh_request("/api/dvr/entry/grid", {"limit": 40})
        self.saved_recordings = []
        if dvr_data and "entries" in dvr_data:
            for item in dvr_data["entries"]:
                state = item.get("sched_status", "")
                self.saved_recordings.append({
                    "id": item.get("uuid", ""),
                    "title": item.get("title", {}).get("eng", "Completed Recording Assets"),
                    "channel": item.get("channelname", "DVB Stream"),
                    "time": "Server Drive",
                    "duration": f"{int(item.get('duration', 0)/60)} Mins",
                    "status": "recording" if state in ("recording", "active") else "completed"
                })

    def initialize_dashboard_content_grids(self):
        # Build live service cards
        for i in reversed(range(self.view_now_layout.count())):
            if self.view_now_layout.itemAt(i).widget(): self.view_now_layout.itemAt(i).widget().setParent(None)
        
        self.now_channel_cards = []
        for ch in self.discovered_channels:
            card = QWidget(); card.setObjectName("card-row"); lay = QHBoxLayout(card); lay.setContentsMargins(15, 15, 15, 15)
            lbl_name = QLabel(f"CH {ch['number']}: {ch['name']}"); lbl_name.setStyleSheet("font-size: 16px; font-weight:bold;")
            lbl_info = QLabel("Live Transport Stream Hardware Handle"); lbl_info.setStyleSheet("color: #7A8B9E;")
            lay.addWidget(lbl_name, 2); lay.addWidget(lbl_info, 5)
            self.view_now_layout.insertWidget(self.view_now_layout.count()-1, card)
            self.now_channel_cards.append(card)

        # Build structural EPG grid maps
        for i in reversed(range(self.view_timeline_grid.count())):
            if self.view_timeline_grid.itemAt(i).widget(): self.view_timeline_grid.itemAt(i).widget().setParent(None)

        self.timeline_matrix_labels = []
        for row_idx, ch in enumerate(self.discovered_channels[:6]):
            row_blocks = []
            lbl_ch = QLabel(ch["name"]); lbl_ch.setStyleSheet("font-weight: bold; color: #00FFCC;")
            self.view_timeline_grid.addWidget(lbl_ch, row_idx, 0)
            for col_idx, slot in enumerate(["EPG Node A", "EPG Node B", "EPG Node C"]):
                blk = QLabel(slot); blk.setObjectName("grid-block"); blk.setAlignment(Qt.AlignmentFlag.AlignCenter)
                self.view_timeline_grid.addWidget(blk, row_idx, col_idx + 1)
                row_blocks.append(blk)
            self.timeline_matrix_labels.append(row_blocks)

        self.sync_recordings_list_elements()

    def sync_recordings_list_elements(self):
        for i in reversed(range(self.rec_list_sublayout.count())):
            if self.rec_list_sublayout.itemAt(i).widget(): self.rec_list_sublayout.itemAt(i).widget().setParent(None)

        self.rec_row_widgets = []
        for item in self.saved_recordings:
            row = QWidget(); row.setObjectName("rec-row"); row.setProperty("status", item["status"])
            lay = QHBoxLayout(row); lay.setContentsMargins(12, 12, 12, 12)
            
            title = QLabel(item["title"]); ch = QLabel(item["channel"]); meta = QLabel(f"{item['time']} ({item['duration']})")
            status = QLabel("● CAPTURING" if item["status"]=="recording" else "COMPLETED")
            status.setStyleSheet("color:#10B981;" if item["status"]=="recording" else "color:#EF4444;")

            lay.addWidget(title, 3); lay.addWidget(ch, 2); lay.addWidget(meta, 2); lay.addWidget(status, 1)
            self.rec_list_sublayout.addWidget(row)
            self.rec_row_widgets.append(row)

    def transition_to_dashboard(self):
        self.player_container.terminate_decode_layers()
        self.master_stack.setCurrentIndex(self.STAGE_DASHBOARD)
        self.focus_area = FocusArea.SIDEBAR
        self.selected_row = 0
        self.update_navigation_visual_states()

    def update_navigation_visual_states(self):
        for enum_val, label in self.cat_labels.items():
            is_active = (enum_val == self.current_menu_cat)
            label.setProperty("active", "true" if is_active else "false")
            label.setStyleSheet("background-color: rgba(255,255,255,0.08); border-left: 4px solid #00FFFF;" if (is_active and self.focus_area == FocusArea.SIDEBAR) else "")
            label.style().unpolish(label); label.style().polish(label)

        self.sub_stack.setCurrentIndex(self.current_menu_cat.value)
        self.header_title.setText(f"{self.cat_labels[self.current_menu_cat].text()}")

        if self.current_menu_cat == MenuCat.NOW:
            for i, card in enumerate(self.now_channel_cards):
                card.setProperty("focused", "true" if (self.focus_area == FocusArea.CONTENT and i == self.selected_row) else "false")
                card.style().unpolish(card)
        elif self.current_menu_cat == MenuCat.TIMELINE:
            for r, row in enumerate(self.timeline_matrix_labels):
                for c, blk in enumerate(row):
                    blk.setProperty("focused", "true" if (self.focus_area == FocusArea.CONTENT and r == self.selected_row and c == self.selected_col) else "false")
                    blk.style().unpolish(blk)
        elif self.current_menu_cat == MenuCat.RECORDINGS:
            self.card_rec_action.setProperty("focused", "true" if (self.focus_area == FocusArea.CONTENT and self.is_recording_action_focused) else "false")
            self.card_rec_action.style().unpolish(self.card_rec_action)
            for i, row in enumerate(self.rec_row_widgets):
                row.setProperty("focused", "true" if (self.focus_area == FocusArea.CONTENT and not self.is_recording_action_focused and i == self.selected_row) else "false")
                row.style().unpolish(row)

    def keyPressEvent(self, event: QKeyEvent):
        key = event.key()
        stage = self.master_stack.currentIndex()

        if key == Qt.Key.Key_Escape:
            self.player_container.terminate_decode_layers()
            QApplication.restoreOverrideCursor()
            self.close()
            return

        if stage in (self.STAGE_LANG, self.STAGE_TUNER):
            panel = self.view_lang if stage == self.STAGE_LANG else self.view_tuner
            if key == Qt.Key.Key_Up: panel.navigate(-1)
            elif key == Qt.Key.Key_Down: panel.navigate(1)
            elif key in (Qt.Key.Key_Return, Qt.Key.Key_Enter):
                if stage == self.STAGE_LANG: self.master_stack.setCurrentIndex(self.STAGE_TUNER)
                else:
                    self.master_stack.setCurrentIndex(self.STAGE_SCAN)
                    self.execute_hardware_rf_scan()
            return

        if stage == self.STAGE_LIVE_TV:
            if key == Qt.Key.Key_Left: self.transition_to_dashboard()
            elif key in (Qt.Key.Key_Up, Qt.Key.Key_Down):
                step = -1 if key == Qt.Key.Key_Up else 1
                if self.discovered_channels:
                    self.current_channel_index = (self.current_channel_index + step) % len(self.discovered_channels)
                    self.player_container.play_live_channel(self.discovered_channels[self.current_channel_index]["uuid"])
            return

        if stage == self.STAGE_DASHBOARD:
            if self.focus_area == FocusArea.SIDEBAR:
                if key in (Qt.Key.Key_Up, Qt.Key.Key_Down):
                    step = -1 if key == Qt.Key.Key_Up else 1
                    self.current_menu_cat = MenuCat((self.current_menu_cat.value + step) % 4)
                    self.update_navigation_visual_states()
                elif key in (Qt.Key.Key_Return, Qt.Key.Key_Enter):
                    self.focus_area = FocusArea.CONTENT
                    self.selected_row = 0; self.selected_col = 0
                    self.is_recording_action_focused = (self.current_menu_cat == MenuCat.RECORDINGS)
                    self.update_navigation_visual_states()
                elif key == Qt.Key.Key_Left and self.discovered_channels:
                    self.master_stack.setCurrentIndex(self.STAGE_LIVE_TV)
                    self.player_container.play_live_channel(self.discovered_channels[self.current_channel_index]["uuid"])
            
            elif self.focus_area == FocusArea.CONTENT:
                if key == Qt.Key.Key_Left:
                    self.focus_area = FocusArea.SIDEBAR; self.update_navigation_visual_states()
                    return

                if self.current_menu_cat in (MenuCat.NOW, MenuCat.TIMELINE):
                    if key == Qt.Key.Key_Up: self.selected_row = max(0, self.selected_row - 1)
                    elif key == Qt.Key.Key_Down: self.selected_row = min(len(self.discovered_channels) - 1, self.selected_row + 1)
                    elif key == Qt.Key.Key_Left and self.current_menu_cat == MenuCat.TIMELINE: self.selected_col = max(0, self.selected_col - 1)
                    elif key == Qt.Key.Key_Right and self.current_menu_cat == MenuCat.TIMELINE: self.selected_col = min(2, self.selected_col + 1)
                    elif key in (Qt.Key.Key_Return, Qt.Key.Key_Enter):
                        self.current_channel_index = self.selected_row
                        self.master_stack.setCurrentIndex(self.STAGE_LIVE_TV)
                        self.player_container.play_live_channel(self.discovered_channels[self.current_channel_index]["uuid"])

                elif self.current_menu_cat == MenuCat.RECORDINGS:
                    if self.is_recording_action_focused:
                        if key == Qt.Key.Key_Down and self.saved_recordings:
                            self.is_recording_action_focused = False; self.selected_row = 0
                        elif key in (Qt.Key.Key_Return, Qt.Key.Key_Enter):
                            self.sync_dvr_recordings_from_backend()
                            self.sync_recordings_list_elements()
                    else:
                        if key == Qt.Key.Key_Up:
                            if self.selected_row == 0: self.is_recording_action_focused = True
                            else: self.selected_row -= 1
                        elif key == Qt.Key.Key_Down: self.selected_row = min(len(self.saved_recordings) - 1, self.selected_row + 1)
                        elif key in (Qt.Key.Key_Return, Qt.Key.Key_Enter):
                            target = self.saved_recordings[self.selected_row]
                            if target["status"] == "completed":
                                self.master_stack.setCurrentIndex(self.STAGE_LIVE_TV)
                                self.player_container.play_dvr_file(target["id"])

                self.update_navigation_visual_states()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = MasterTVEngine()
    window.show()
    sys.exit(app.exec())