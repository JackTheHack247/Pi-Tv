class VideoPlaybackContainer(QFrame):
    def __init__(self):
        super().__init__()
        self.setFrameShape(QFrame.Shape.NoFrame)
        self.setStyleSheet("background-color: #000000;")
        
        # Instantiate libvlc software runtime thread bindings
        self.vlc_instance = vlc.Instance("--no-xlib --quiet --network-caching=500")
        self.media_player = self.vlc_instance.media_player_new()

    def play_live_channel(self, channel_uuid):
        """Attaches directly to a native network hardware MPEG-TS streaming pipe."""
        self.media_player.stop()
        auth = f"{TVH_USER}:{TVH_PASS}@" if TVH_USER and TVH_PASS else ""
        stream_url = f"http://{auth}{TVH_HOST}:{TVH_PORT}/stream/channel/{channel_uuid}"
        
        media = self.vlc_instance.media_new(stream_url)
        self.media_player.set_media(media)
        
        # Crucial cross-platform window handle mapping injection
        if sys.platform.startswith('linux'):
            self.media_player.set_xwindow(int(self.winId()))
        elif sys.platform == "win32":
            self.media_player.set_hwnd(int(self.winId()))
        elif sys.platform == "darwin":
            self.media_player.set_nsobject(int(self.winId()))
            
        self.media_player.play()

    def play_dvr_file(self, dvr_uuid):
        """Attaches directly to an uncompressed stored file transport payload stream."""
        self.media_player.stop()
        auth = f"{TVH_USER}:{TVH_PASS}@" if TVH_USER and TVH_PASS else ""
        stream_url = f"http://{auth}{TVH_HOST}:{TVH_PORT}/dvrfile/{dvr_uuid}"
        
        media = self.vlc_instance.media_new(stream_url)
        self.media_player.set_media(media)

        if sys.platform.startswith('linux'):
            self.media_player.set_xwindow(int(self.winId()))
        elif sys.platform == "win32":
            self.media_player.set_hwnd(int(self.winId()))
        elif sys.platform == "darwin":
            self.media_player.set_nsobject(int(self.winId()))

        self.media_player.play()

    def terminate_decode_layers(self):
        self.media_player.stop()

class WizardSelectPanel(QWidget):
    def __init__(self, title, subtitle, data_list):
        super().__init__()
        self.data = data_list
        self.index = 0
        master = QHBoxLayout(self); master.addStretch(3)
        center = QWidget(); self.layout = QVBoxLayout(center); self.layout.setAlignment(Qt.AlignmentFlag.AlignCenter)
        
        t_lbl = QLabel(title); t_lbl.setObjectName("title")
        s_lbl = QLabel(subtitle); s_lbl.setObjectName("subtitle")
        self.layout.addWidget(t_lbl); self.layout.addWidget(s_lbl)
        
        self.labels = []
        for item in self.data:
            lbl = QLabel(item); lbl.setObjectName("item-lbl"); lbl.setAlignment(Qt.AlignmentFlag.AlignCenter)
            self.layout.addWidget(lbl)
            self.labels.append(lbl)
        master.addWidget(center, 4); master.addStretch(3)
        self.refresh()

    def refresh(self):
        for i, lbl in enumerate(self.labels):
            lbl.setProperty("selected", "true" if i == self.index else "false")
            lbl.style().unpolish(lbl); lbl.style().polish(lbl)

    def navigate(self, direction):
        self.index = max(0, min(len(self.data) - 1, self.index + direction))
        self.refresh()

